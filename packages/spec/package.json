{
  "name": "@finterion/charts-spec",
  "version": "1.1.0",
  "description": "JSON-only ChartSpec schema, validator and compiler for Finterion Charts. Designed for LLM agents and forum/iframe embedding.",
  "keywords": [
    "chart",
    "charts",
    "schema",
    "json-schema",
    "llm",
    "finance"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "Finterion",
  "homepage": "https://github.com/Finterion/charts/tree/main/packages/spec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Finterion/charts.git",
    "directory": "packages/spec"
  },
  "bugs": {
    "url": "https://github.com/Finterion/charts/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@finterion/charts-core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
