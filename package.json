{
  "name": "finterion-charts",
  "version": "0.0.0",
  "private": true,
  "description": "Finterion Charts — lightweight, neon-styled charting for React",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "size": "size-limit",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "tsup": "^8.3.0",
    "vitest": "^2.1.1",
    "@changesets/cli": "^2.27.9",
    "size-limit": "^11.1.6",
    "@size-limit/preset-small-lib": "^11.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
